.git
.gitignore
.github

# ruflo / claude-flow runtime state
.claude
.claude-flow
.swarm
*.db
memory

# Tests, coverage, docs — not needed at runtime
coverage
docs

# Editor / OS cruft
.vscode
.idea
.DS_Store
*.log

# Existing container files
Dockerfile
.dockerignore
docker-compose*.yml
